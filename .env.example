# --- Database (Neon / Render PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host:5432/lichnosty"

# --- Redis (Upstash / Render Redis) ---
REDIS_URL="redis://default:password@host:6379"

# --- DeepSeek API ---
DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# --- Site ---
NEXT_PUBLIC_URL="https://lichnosty.onrender.com"
SITE_NAME="Личности"

# --- Cron / internal auth ---
# Generate with: openssl rand -hex 32
CRON_SECRET="replace-me-with-random-hex"
REVALIDATE_SECRET="replace-me-with-random-hex"

# --- Optional data sources ---
RAPIDAPI_KEY=""
INDEXNOW_KEY=""
GOOGLE_INDEXING_API_KEY=""

# --- Migration from old WordPress ---
WP_SOURCE_URL="https://lichnosty.ru"
WP_APP_USER=""
WP_APP_PASSWORD=""
